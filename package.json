{
  "name": "airdrop-bench-tests",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run --maxWorkers=1",
    "test:watch": "vitest",
    "bench": "tsx bench/run-all.ts",
    "bench:proof": "tsx bench/proof.bench.ts",
    "bench:double-claim": "tsx bench/doubleClaim.bench.ts",
    "build:airdrop-temp": "tsx scripts/generate-airdrop.ts",
    "compile:matrix": "tsx scripts/compile-matrix.ts",
