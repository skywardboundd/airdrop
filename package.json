    "claim": "blueprint run claimAirdrop",
    "check": "blueprint run checkClaim"
  },
  "devDependencies": {
    "@ton/blueprint": "^0.44.2",
    "@ton/core": "^0.63.1",
    "@ton/crypto": "^3.3.0",
    "@ton/sandbox": "^0.41.0",
    "@ton/ton": "^16.2.4",
    "@types/node": "^24.0.0",
    "tinybench": "^2.9.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
